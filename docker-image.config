# Docker image build/push config (tracked in git).
# Edit VERSION when cutting a new release; "latest" will point to this.
IMAGE=darknetz/php-rand
TAG=latest
VERSION=v1.2.7

# GitHub Container Registry (optional). Requires GITHUB_TOKEN in .env or .env.local to push.
GHCR_IMAGE=ghcr.io/darknetzz/php-rand
