# Copy to .env.local (or .env) and fill in. Not committed (secrets only).
# Use .env.local so your secrets survive git pull/merge ( .env was removed from repo history and can be re-deleted on merge ).
# GITHUB_TOKEN=ghp_xxx   # PAT with write:packages, for pushing to ghcr.io (or: gh auth refresh -s write:packages)
# DOCKERHUB_USERNAME=    # optional; non-interactive Docker Hub login in docker-pushimage.sh
# DOCKERHUB_TOKEN=        # optional Docker Hub access token
# SKIP_DOCKERHUB=1        # GHCR-only local publish when Actions are disabled
